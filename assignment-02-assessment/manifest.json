{
  "manifest_version": 3,
  "name": "CompetencyAssess",
  "version": "1.0",
  "description": "Self-assessment tool for PDF-based competency testing powered by Gemini",
  "permissions": ["storage"],
  "host_permissions": ["https://generativelanguage.googleapis.com/*", "<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "CompetencyAssess"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  }
}
