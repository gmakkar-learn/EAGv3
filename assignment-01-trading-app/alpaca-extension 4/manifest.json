{
  "manifest_version": 3,
  "name": "Alpaca Paper Trader",
  "version": "1.0",
  "description": "Paper trading dashboard for Alpaca Markets",
  "permissions": ["storage"],
  "host_permissions": ["https://paper-api.alpaca.markets/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
